# -----------------------------------------------
# Environment files
# Real values must never be committed.
# Copy environment.example.ts → environment.ts
# and environment.prod.example.ts → environment.prod.ts,
# then fill in your Firebase config values.
# -----------------------------------------------
src/environments/environment.ts
src/environments/environment.prod.ts
.env
.env.*
!.env.example

# -----------------------------------------------
# Test output
# -----------------------------------------------
/coverage
__screenshots__/
testem.log

# -----------------------------------------------
